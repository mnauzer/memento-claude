# ==============================================
# MEMENTO DATABASE - ENVIRONMENT VARIABLES
# ==============================================
# IMPORTANT: Never commit .env files to git!
# Copy this file to .env and fill in your actual values

# Memento Database API Key
# Get from: https://mementodatabase.com/settings/api
MEMENTO_API_KEY=your_memento_api_key_here

# Telegram Bot Configuration (stored in Memento Database)
# These are field names, not actual values
# Actual values are in ASISTANTO Defaults library

# N8N Configuration (if used)
# N8N_URL=your_n8n_instance_url
# N8N_USERNAME=your_n8n_username
# N8N_PASSWORD=your_n8n_password

# OpenAI API Key (stored in Memento Database)
# OPENAI_API_KEY=your_openai_key (stored in ASISTANTO API library)

# Claude API Key (stored in Memento Database)
# ANTHROPIC_API_KEY=your_claude_key (stored in ASISTANTO API library)
