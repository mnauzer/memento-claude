# MCP Knowledge Retriever Configuration

# Server
MCP_PORT=9200
MCP_DEBUG=false
LOG_LEVEL=INFO

# Neo4j Graph Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# PostgreSQL with pgvector
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=hades_knowledge
POSTGRES_DSN=postgresql://postgres:password@localhost:5432/hades_knowledge

# Skill behavior
MAX_RESULTS=10
TIMEOUT_SECONDS=30
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300
