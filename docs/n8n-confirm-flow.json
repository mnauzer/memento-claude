{
  "name": "✅ Greta Krajinka — Signature Confirm Handler",
  "nodes": [
    {
      "id": "tg-trigger",
      "name": "Telegram Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "webhookId": "krajinka-callback-hook",
      "position": [
        240,
        300
      ],
      "parameters": {
        "httpMethod": "POST",
        "path": "krajinka-callback",
        "responseMode": "onReceived",
        "options": {}
      }
    },
    {
      "id": "flatten-update",
      "name": "Flatten Update",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        300
      ],
      "parameters": {
        "jsCode": "return [{ json: $input.first().json.body }];"
      }
    },
    {
      "id": "is-callback",
      "name": "Is Callback Query?",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [
        680,
        300
      ],
      "parameters": {
        "mode": "rules",
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true
                },
                "conditions": [
                  {
                    "leftValue": "={{ !!$json.callback_query }}",
                    "rightValue": true,
                    "operator": {
                      "type": "boolean",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "callback_query"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "parse-callback",
      "name": "Parse Callback",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        200
      ],
      "parameters": {
        "jsCode": "const update = $input.first().json;\nconst query = update.callback_query;\nconst data = query.data || '';\n\n// Format: \"sign_{podpisId}_{action}\"\n// podpisId = Memento Cloud ID of the podpis entry (individual GET works)\nif (!data.startsWith('sign_')) {\n  return [{ json: { skip: true, data } }];\n}\n\nconst lastIdx = data.lastIndexOf('_');\nconst action = data.substring(lastIdx + 1);   // 'confirm' or 'reject'\nconst podpisId = data.substring(5, lastIdx);  // Memento Cloud ID of podpis entry\n\nif ((action !== 'confirm' && action !== 'reject') || !podpisId) {\n  return [{ json: { skip: true, data } }];\n}\n\nconst confirmed = action === 'confirm';\nconst callbackQueryId = query.id;\nconst chatId = String(query.message.chat.id);\nconst messageId = query.message.message_id;\nconst originalText = query.message.text || '';\nconst fromFirst = query.from.first_name || '';\nconst fromLast = query.from.last_name || '';\nconst fromName = (fromFirst + ' ' + fromLast).trim();\nconst fromChatId = String(query.from.id);\nconst confirmText = confirmed\n  ? String.fromCharCode(10004) + ' Potvrden\\u00e9'\n  : String.fromCharCode(10060) + ' Odmietnut\\u00e9';\n\nreturn [{ json: {\n  action, podpisId, confirmed, callbackQueryId, chatId, messageId,\n  originalText, fromName, fromChatId, confirmText, skip: false\n} }];"
      }
    },
    {
      "id": "is-sign-callback",
      "name": "Is Sign Callback?",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [
        1120,
        200
      ],
      "parameters": {
        "mode": "rules",
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.skip }}",
                    "rightValue": false,
                    "operator": {
                      "type": "boolean",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "sign_callback"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "answer-callback",
      "name": "Answer Callback Query",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1340,
        80
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.telegram.org/bot{{TELEGRAM_BOT_TOKEN}}/answerCallbackQuery",
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ callback_query_id: $('Parse Callback').first().json.callbackQueryId, text: $('Parse Callback').first().json.confirmText, show_alert: false }) }}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      }
    },
    {
      "id": "edit-message-text",
      "name": "Edit Message Text",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1340,
        260
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.telegram.org/bot{{TELEGRAM_BOT_TOKEN}}/editMessageText",
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ chat_id: $('Parse Callback').first().json.chatId, message_id: $('Parse Callback').first().json.messageId, text: $('Parse Callback').first().json.originalText + '\\n\\n' + $('Parse Callback').first().json.confirmText + ' — ' + $('Parse Callback').first().json.fromName, parse_mode: 'HTML' }) }}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      }
    },
    {
      "id": "get-podpis",
      "name": "GET Podpis Entry",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1340,
        440
      ],
      "parameters": {
        "method": "GET",
        "url": "=https://api.mementodatabase.com/v1/libraries/2fNM2Za4G/entries/{{ $('Parse Callback').first().json.podpisId }}",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "token",
              "value": "{{MEMENTO_API_TOKEN}}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      }
    },
    {
      "id": "extract-fields",
      "name": "Extract Podpis Fields",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1560,
        440
      ],
      "parameters": {
        "jsCode": "// GET individual podpis entry -> extract Zdroj ID, Kniznica -> determine source library\nconst podpisEntry = $input.first().json;\nconst confirmed = $('Parse Callback').first().json.confirmed;\n\nconst fields = podpisEntry.fields || [];\nvar zdrojId = '';\nvar kniznica = '';\n\nfields.forEach(function(f) {\n  if (f.name === 'Zdroj ID') zdrojId = String(f.value || '');\n  if (f.name === 'Kni\\u017enica') kniznica = String(f.value || '').trim();\n});\n\nvar libMap = {};\nlibMap['Doch\\u00e1dzka'] = { libId: 'zNoMvrv8U', statusField: 'Stav podpisov' };\nlibMap['Pokladn\\u0148a']   = { libId: 'g9eS5Ny2E', statusField: 'Stav podpisu'  };\nvar lib = libMap[kniznica] || null;\n\nreturn [{ json: {\n  podpisId:    podpisEntry.id,\n  stavValue:   confirmed ? 'Potvrdil' : 'Odmietol',\n  zdrojId:     zdrojId,\n  sourceLibId: lib ? lib.libId : '',\n  sourceField: lib ? lib.statusField : '',\n  hasSource:   !!(lib && zdrojId),\n  kniznica:    kniznica\n}}];"
      }
    },
    {
      "id": "patch-podpis",
      "name": "PATCH Podpis Stav",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1780,
        340
      ],
      "parameters": {
        "method": "PATCH",
        "url": "=https://api.mementodatabase.com/v1/libraries/2fNM2Za4G/entries/{{ $json.podpisId }}",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "token",
              "value": "{{MEMENTO_API_TOKEN}}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={\n  \"fields\": [\n    { \"name\": \"Stav\", \"value\": \"{{ $json.stavValue }}\" },\n    { \"name\": \"Dátum potvrdenia\", \"value\": \"{{ $now.format('yyyy-MM-dd') }}\" }\n  ]\n}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      }
    },
    {
      "id": "has-source",
      "name": "Has Source Library?",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [
        1780,
        540
      ],
      "parameters": {
        "mode": "rules",
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.hasSource }}",
                    "rightValue": true,
                    "operator": {
                      "type": "boolean",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "has_source"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "patch-source",
      "name": "PATCH Source Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2000,
        540
      ],
      "parameters": {
        "method": "PATCH",
        "url": "=https://api.mementodatabase.com/v1/libraries/{{ $json.sourceLibId }}/entries/{{ $json.zdrojId }}",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "token",
              "value": "{{MEMENTO_API_TOKEN}}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={\n  \"fields\": [\n    { \"name\": \"{{ $json.sourceField }}\", \"value\": \"{{ $json.stavValue }}\" }\n  ]\n}",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      }
    }
  ],
  "connections": {
    "Telegram Webhook": {
      "main": [
        [
          {
            "node": "Flatten Update",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Flatten Update": {
      "main": [
        [
          {
            "node": "Is Callback Query?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Is Callback Query?": {
      "main": [
        [
          {
            "node": "Parse Callback",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    },
    "Parse Callback": {
      "main": [
        [
          {
            "node": "Is Sign Callback?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Is Sign Callback?": {
      "main": [
        [
          {
            "node": "Answer Callback Query",
            "type": "main",
            "index": 0
          },
          {
            "node": "Edit Message Text",
            "type": "main",
            "index": 0
          },
          {
            "node": "GET Podpis Entry",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    },
    "GET Podpis Entry": {
      "main": [
        [
          {
            "node": "Extract Podpis Fields",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Extract Podpis Fields": {
      "main": [
        [
          {
            "node": "PATCH Podpis Stav",
            "type": "main",
            "index": 0
          },
          {
            "node": "Has Source Library?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Has Source Library?": {
      "main": [
        [
          {
            "node": "PATCH Source Status",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "callerPolicy": "workflowsFromSameOwner",
    "availableInMCP": false
  },
  "staticData": null,
  "_comment": "v3 — 2026-03-22: Use podpisId (Memento Cloud entry ID) in callback_data. Confirm flow does individual GET by podpisId to get fields (Zdroj ID, Kniznica), then PATCHes both the podpis entry and the source (Dochadzka/Pokladna) entry. Bulk GET API returns entries with empty fields[] so field-based search is not possible."
}