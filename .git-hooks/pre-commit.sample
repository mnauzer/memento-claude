#!/bin/bash
# ==============================================
# PRE-COMMIT HOOK - Security Check
# ==============================================
# Copy this to .git/hooks/pre-commit and make executable:
# cp .git-hooks/pre-commit.sample .git/hooks/pre-commit
# chmod +x .git/hooks/pre-commit

echo "🔒 Running security checks..."

# Files that are allowed to contain security-related strings (documentation, cleanup scripts)
EXEMPT_PATTERN="(SECURITY_CHECKLIST\.md|SECURITY\.md|cleanup-git-history\.sh|\.git-hooks/|install-hooks\.sh)"

# Check for potential API keys, tokens, passwords
FORBIDDEN_PATTERNS=(
    "sk-[a-zA-Z0-9]{20,}"              # OpenAI keys
    "ghp_[a-zA-Z0-9]{36}"               # GitHub tokens
    "[0-9]{8,}:[a-zA-Z0-9_-]{35}"      # Telegram bot tokens
    "AKIA[0-9A-Z]{16}"                  # AWS keys
    "hx7GjATH"                          # Known compromised key pattern
)

FOUND_ISSUES=0

# Get list of changed files, excluding exempt files
CHANGED_FILES=$(git diff --cached --name-only | grep -vE "$EXEMPT_PATTERN" || true)

if [ ! -z "$CHANGED_FILES" ]; then
    for pattern in "${FORBIDDEN_PATTERNS[@]}"; do
        for file in $CHANGED_FILES; do
            if git diff --cached "$file" | grep -qE "$pattern"; then
                echo "❌ ERROR: Potential secret detected in: $file"
                echo "   Pattern: $pattern"
                echo "   Please remove sensitive data before committing."
                FOUND_ISSUES=1
            fi
        done
    done
fi

# Check for personal paths (excluding exempt files)
if [ ! -z "$CHANGED_FILES" ]; then
    for file in $CHANGED_FILES; do
        if git diff --cached "$file" | grep -qE "/home/[a-z]+/|C:\\\\Users\\\\[^\\\\]+\\\\"; then
            echo "⚠️  WARNING: Personal file path detected in: $file"
            echo "   Consider using {project_root} or relative paths instead."
        fi
    done
fi

# Check for .env files (should never be committed)
if git diff --cached --name-only | grep -qE "^\.env$|/\.env$"; then
    echo "❌ ERROR: Attempting to commit .env file!"
    echo "   .env files should NEVER be committed."
    echo "   Use .env.example instead."
    FOUND_ISSUES=1
fi

if [ $FOUND_ISSUES -eq 1 ]; then
    echo ""
    echo "❌ Commit rejected due to security concerns."
    echo "   Fix the issues above and try again."
    exit 1
fi

echo "✅ Security checks passed!"
exit 0
